{
  "name": "@stacksjs/eslint-config",
  "type": "module",
  "version": "4.2.0-beta.4",
  "description": "Stacks ESLint config",
  "author": "Anthony Fu <anthonyfu117@hotmail.com> (https://github.com/antfu/)",
  "license": "MIT",
  "funding": "https://github.com/sponsors/antfu",
  "homepage": "https://github.com/stacksjs/eslint-config",
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --clean --dts",
    "stub": "tsup",
    "dev": "bunx @eslint/config-inspector --config eslint.config.js",
    "build:inspector": "bun run build && npx @eslint/config-inspector build",
    "watch": "tsup --watch",
    "lint": "bunx --bun eslint .",
    "lint:fix": "bunx --bun eslint . --fix",
    "typegen": "bun scripts/typegen.ts",
    "prepack": "bun run build",
    "changelog": "bunx changelogen --output CHANGELOG.md",
    "release": "bun run changelog && bunx bumpp package.json --all",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "bun simple-git-hooks"
  },
  "dependencies": {
    "@antfu/install-pkg": "^1.0.0",
    "@clack/prompts": "^0.10.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.4.1",
    "@eslint/markdown": "^6.2.2",
    "@stacksjs/eslint-plugin": "^0.1.5",
    "@stylistic/eslint-plugin": "^4.0.0-beta.1",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "@vitest/eslint-plugin": "^1.1.27",
    "eslint-config-flat-gitignore": "^2.0.0",
    "eslint-flat-config-utils": "^2.0.1",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-antfu": "^3.0.0",
    "eslint-plugin-command": "^3.0.0",
    "eslint-plugin-import-x": "^4.6.1",
    "eslint-plugin-jsdoc": "^50.6.3",
    "eslint-plugin-jsonc": "^2.19.1",
    "eslint-plugin-n": "^17.15.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^4.8.0",
    "eslint-plugin-regexp": "^2.7.0",
    "eslint-plugin-toml": "^0.12.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-plugin-vue": "^9.32.0",
    "eslint-plugin-yml": "^1.16.0",
    "eslint-processor-vue-blocks": "^2.0.0",
    "globals": "^15.14.0",
    "jsonc-eslint-parser": "^2.4.0",
    "local-pkg": "^1.0.0",
    "parse-gitignore": "^2.0.0",
    "toml-eslint-parser": "^0.10.0",
    "vue-eslint-parser": "^9.4.3",
    "yaml-eslint-parser": "^1.2.3"
  },
  "devDependencies": {
    "@eslint-community/eslint-utils": "^4.4.1",
    "@eslint/config-inspector": "^1.0.0",
    "@prettier/plugin-xml": "^3.4.1",
    "@types/bun": "^1.1.18",
    "@types/fs-extra": "^11.0.4",
    "@typescript-eslint/utils": "^8.21.0",
    "bumpp": "^10.0.2",
    "eslint": "^9.20.0",
    "eslint-plugin-format": "^1.0.1",
    "@unocss/eslint-plugin": "^65.4.3",
    "eslint-typegen": "^1.0.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.0",
    "lint-staged": "^15.4.3",
    "rimraf": "^6.0.1",
    "simple-git-hooks": "^2.11.1",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "vue": "^3.5.13"
  },
  "resolutions": {
    "@eslint-community/eslint-utils": "^4.4.1",
    "@typescript-eslint/utils": "^8.23.0",
    "eslint": "^9.20.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*": "bunx --bun eslint --fix"
  },
  "workspaces": [
    "fixtures/*"
  ]
}
